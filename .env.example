# ---------------------------------------------------------------------------
# MarketPulse X — Environment configuration
# Copy this file to `.env` (local dev) and set values in the Render dashboard.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# AI provider for post analysis. Pick ONE (or leave both blank to run the free
# heuristic fallback). Which one is used is controlled by AI_PROVIDER below.
# ---------------------------------------------------------------------------

# AI_PROVIDER: anthropic | openai | auto  (default: auto)
#   auto  → use Anthropic if ANTHROPIC_API_KEY is set, else OpenAI, else heuristic
AI_PROVIDER=auto

# Anthropic (Claude) — cheapest good option. Claude Haiku costs fractions of a
# cent per post; a few dollars lasts a very long time. Get a key at
# https://console.anthropic.com/settings/keys  (add a small amount of credit).
ANTHROPIC_API_KEY=
# Optional: override the model (defaults to claude-haiku-4-5, the cheapest).
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI (optional alternative). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: override the OpenAI model (defaults to gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Finnhub — live market/news data provider (quotes, market news, company news).
# Server-side only: the key is read via process.env.FINNHUB_API_KEY inside the
# /api routes and is NEVER shipped to the browser. Free tier at
# https://finnhub.io/register  (news-sentiment is a premium endpoint and
# degrades gracefully to `supported: false`). If unset, the app serves clean,
# clearly-labeled demo market data instead of crashing.
FINNHUB_API_KEY=

# Database connection string.
#   Local dev (SQLite):   file:./dev.db
#   Render (PostgreSQL):  postgresql://user:pass@host:5432/dbname
# NOTE: also set the matching provider in prisma/schema.prisma (see README).
DATABASE_URL="file:./dev.db"

# Shared secret required to call the protected admin refresh endpoint.
# Send as `Authorization: Bearer <ADMIN_SECRET>` or `x-admin-secret` header.
ADMIN_SECRET=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# FREE post sources. The app pulls from multiple free providers (no paid X API).
# Configure the accounts/platforms in config/accounts.ts.
# ---------------------------------------------------------------------------

# Nitter-compatible instances for X/Twitter (tried in order, with fallback).
NITTER_INSTANCES=https://nitter.net,https://xcancel.com,https://nitter.poast.org

# RSSHub instances — free RSS gateway for many platforms (tried in order).
RSSHUB_INSTANCES=https://rsshub.app

# Bluesky public read API base (no auth required).
BLUESKY_API=https://public.api.bsky.app

# Optional: restrict which source types are active (comma-separated). Empty =
# all. Types: nitter,rsshub,mastodon,bluesky,reddit,youtube,rss
ENABLED_SOURCES=

# How often (minutes) the polling worker should run. Used by the cron trigger.
POLL_INTERVAL_MINUTES=15

# Maximum number of recent posts fetched per account per poll.
MAX_POSTS_PER_ACCOUNT=5

# Optional: when "true" AND NODE_ENV=production AND the database is empty,
# /api/posts serves a few clearly-labeled demo posts so a brand-new deployment
# is never blank. Leave "false" for real data only.
DEMO_FALLBACK=false
